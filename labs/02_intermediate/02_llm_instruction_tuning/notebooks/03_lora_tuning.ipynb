    "# model = PeftModel.from_pretrained(base_model, \"./lora_adapter_final\")\n",
    "# model = model.merge_and_unload()  # Optional: merge LoRA weights with base model"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 8: Test the Fine-tuned Model\n",
    "\n",
    "Let's generate some text with our fine-tuned model to see if it learned anything."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test generation with the fine-tuned model\n",
    "from transformers import GenerationConfig\n",
    "\n",
    "# Set model to evaluation mode\n",
    "model.eval()\n",
    "\n",
    "# Test prompt\n",
    "test_prompt = \"\"\"### Instruction:\n",
    "What is the importance of experiment tracking in MLOps?\n",
    "\n",
    "### Input:\n",
    "\n",
    "### Response:\n",
    "\"\"\"\n",
    "\n",
    "# Tokenize input\n",
    "inputs = tokenizer(test_prompt, return_tensors=\"pt\").to(model.device)\n",
    "\n",
    "# Generate\n",
    "with torch.no_grad():\n",
    "    outputs = model.generate(\n",
    "        **inputs,\n",
    "        max_new_tokens=100,\n",
    "        temperature=0.7,\n",
    "        do_sample=True,\n",
    "        pad_token_id=tokenizer.eos_token_id\n",
    "    )\n",
    "\n",
    "# Decode and print\n",
    "response = tokenizer.decode(outputs[0], skip_special_tokens=True)\n",
    "print(\"Generated response:\")\n",
    "print(response)"
   ]
  },
  {
   "cell_type": "markdown",
